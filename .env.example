# ── CLI / pipeline environment variables ─────────────────────────
# Copy to .env at the repo root and fill in your values.
# These are used by orchestrator.py and the pipeline agents.

# LLM provider: openrouter | gemini | nvidia
PROVIDER=openrouter

# OpenRouter (get keys at https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-v1-...
# Optional: comma-separated fallback keys tried in order on quota/auth errors
# OPENROUTER_API_KEYS=sk-or-v1-key2,sk-or-v1-key3

# NVIDIA NIM (get at https://build.nvidia.com/)
# NVIDIA_API_KEY=nvapi-...

# Gemini direct (get at https://aistudio.google.com)
# GEMINI_KEY_1=AIza...
# GEMINI_KEY_2=AIza...
# GEMINI_MODEL=gemini-2.5-flash-preview-04-17

# Per-agent model overrides (default: google/gemini-2.5-flash via OpenRouter)
# MODEL_ANALYZER=google/gemini-2.5-flash
# MODEL_PLANNER=google/gemini-2.5-flash
# MODEL_DESIGNER=google/gemini-2.5-flash
# MODEL_ASSEMBLER=google/gemini-2.5-flash
# MODEL_CRITIC=google/gemini-2.5-flash

# Visual style: notebooklm | modern | dark | auto
# VISUAL_STYLE=auto
