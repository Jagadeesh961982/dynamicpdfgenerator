# Copy to fastapi-app/.env — loaded automatically via app.core.config.Settings

FERNET_KEY=
JWT_SECRET=change-me-to-a-long-random-string
# REPO_ROOT=  # override repository root (parent of fastapi-app/)
# DATABASE_URL=sqlite:///data/api.sqlite3
# STORAGE_ROOT=
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# Comma-separated browser origins for CORS (required when using the SPA on another port)
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
