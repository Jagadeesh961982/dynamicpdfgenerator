# Copy to fastapi-app/.env — loaded automatically via app.core.config.Settings

# ==========================================
# ── FastAPI Security Configurations ────
# ==========================================
# symmetric key for encrypting intermediate documents in database storage
# Generate via: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=your_fernet_symmetric_key_here

# JSON Web Token secret key signing credentials safely
JWT_SECRET=your_jwt_signature_secret_here

# ==========================================
# ── LLM Pipeline Routing Controls ─────────
# ==========================================
# Set to 'gemini' for native Google AI Studio SDK or 'openrouter' for fallbacks
PROVIDER=gemini

# Primary pipeline routing model (fallback-ready runtime)
GEMINI_MODEL=gemma-4-31b-it

# Rotated API Keys (To prevent Rate Limit failures during parallel cascading tasks)
# Paste up to three distinct Google Gemini API keys (obtainable at https://aistudio.google.com)
GEMINI_KEY_1=your_gemini_api_key_one_here
GEMINI_KEY_2=your_gemini_api_key_two_here
GEMINI_KEY_3=your_gemini_api_key_three_here

# ==========================================
# ── Fallback Providers & External Hosts ───
# ==========================================
# OpenRouter configs (Useful if querying google/gemma-4-31b-it:free models directly)
OPENROUTER_API_KEY=your_openrouter_api_key
OPENROUTER_SITE_NAME="NotebookLM PDF Generator"

# NVIDIA NIM / Ollama or custom local execution endpoints
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# ==========================================
# ── Fine-Grained Model Targets Per Agent ──
# ==========================================
# Note: Active when PROVIDER=openrouter or PROVIDER=nvidia
MODEL_ANALYZER=google/gemma-4-31b-it:free
MODEL_PLANNER=google/gemma-4-31b-it:free
MODEL_DESIGNER=google/gemma-4-31b-it:free
MODEL_ASSEMBLER=google/gemma-4-31b-it:free
MODEL_CRITIC=google/gemma-4-31b-it:free
