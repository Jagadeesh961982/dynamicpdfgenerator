# Copy to fastapi-app/.env — loaded automatically via app.core.config.Settings
#
# Generate FERNET_KEY:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Generate JWT_SECRET:
#   python -c "import secrets; print(secrets.token_hex(32))"

FERNET_KEY=
JWT_SECRET=change-me-to-a-long-random-string

# Database (default: data/api.sqlite3 relative to repo root)
# DATABASE_URL=sqlite:///data/api.sqlite3
# For PostgreSQL: DATABASE_URL=postgresql+psycopg2://user:pass@host/db

# Storage root for job artifacts (default: data/storage)
# STORAGE_ROOT=

# Token expiry in minutes (default: 7 days)
# ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated browser origins for CORS
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Rate limiting: max job submissions per user per minute (default: 5)
# JOB_RATE_LIMIT=5

# Max upload size in MB (default: 20)
# MAX_UPLOAD_MB=20

# Log file path (default: logs/api.log relative to fastapi-app/)
# LOG_FILE=logs/api.log

# Repo root override (rarely needed)
# REPO_ROOT=
